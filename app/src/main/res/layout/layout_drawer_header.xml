<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerHeaderRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/afc_black"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivProfileAvatar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher_round" />

    <TextView
        android:id="@+id/tvProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Guest User"
        android:textColor="@color/afc_white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProfileAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="No address provided"
        android:textColor="@color/afc_text_secondary"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@color/afc_dark_grey" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangeAddress"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="start|center_vertical"
        android:text="Change Address"
        android:textColor="@color/afc_white"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconTint="@color/afc_white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:text="Logout"
        android:textColor="@color/afc_red"
        app:icon="@android:drawable/ic_lock_power_off"
        app:iconTint="@color/afc_red" />

</LinearLayout>
